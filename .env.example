# Agent Template - Root Environment Variables
# Copy this to .env and customize for your project

# Supabase Database
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Hermes Agent (DigitalOcean)
HERMES_BASE_URL=http://YOUR_DROPLET_IP:8642
HERMES_API_PASSWORD=your-hermes-password

# Google AI (for Hermes agent)
GOOGLE_API_KEY=your-google-api-key

# Optional: Skip subscription check for testing
SKIP_SUBSCRIPTION_CHECK=false