# Agent Template - Root Environment Variables
# Copy this to .env and customize for your project

# ============================================================================
# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings
# ============================================================================

# Database connection (use "Direct connection" for migrations)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Project credentials
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================================
# Hermes Agent Configuration (DigitalOcean Deployment)
# ============================================================================

# Hermes API endpoint (set after deploying to DigitalOcean)
HERMES_BASE_URL=http://YOUR_DROPLET_IP:8642

# API password (must match API_SERVER_KEY in hermes-agent/.env)
# Generate with: openssl rand -base64 32
HERMES_API_PASSWORD=your-secure-password-here

# ============================================================================
# AI Provider API Keys
# ============================================================================

# Google AI Studio (required for Gemini models)
GOOGLE_API_KEY=your-google-api-key-here

# Optional: Additional AI providers
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ============================================================================
# Optional: Rate Limiting (Upstash Redis)
# Get from: https://upstash.com/
# ============================================================================

# UPSTASH_REDIS_URL=your-redis-url
# UPSTASH_REDIS_TOKEN=your-redis-token

# ============================================================================
# Development Settings
# ============================================================================

# Skip subscription validation during development
SKIP_SUBSCRIPTION_CHECK=true

# ============================================================================
# Edge Function Secrets (set via Supabase CLI)
# ============================================================================
#
# After setting up your .env, also configure Supabase secrets:
#
# supabase secrets set HERMES_BASE_URL=http://your-droplet-ip:8642
# supabase secrets set HERMES_API_PASSWORD=your-password
# supabase secrets set GOOGLE_API_KEY=your-google-key
# supabase secrets set SKIP_SUBSCRIPTION_CHECK=true
#
# Optional rate limiting:
# supabase secrets set UPSTASH_REDIS_URL=your-redis-url
# supabase secrets set UPSTASH_REDIS_TOKEN=your-redis-token