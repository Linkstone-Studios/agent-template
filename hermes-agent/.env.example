# Hermes Agent Environment Variables
# Copy this file to .env and fill in your values

# Required: API Server password (generate with: openssl rand -base64 32)
API_SERVER_KEY=change-me-to-a-secure-password

# Model Configuration
DEFAULT_MODEL=gemini-3-flash-preview
FALLBACK_MODEL=gemini-1.5-flash

# Provider API Keys (at least one required)

# Google AI Studio (gemini models)
GOOGLE_API_KEY=your-google-api-key

# OpenAI (gpt models) - optional
# OPENAI_API_KEY=your-openai-api-key

# Anthropic (claude models) - optional
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: Enable Hermes Telemetry
# HERMES_TELEMETRY_ENABLED=true

# Optional: Custom skills directory
# HERMES_SKILLS_DIR=/root/.hermes/skills