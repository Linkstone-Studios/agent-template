# Hermes Agent Environment Variables
# Copy this file to .env and fill in your values

# Required: API Server password (generate with: openssl rand -base64 32)
API_SERVER_KEY=change-me-to-a-secure-password

# Model Configuration
DEFAULT_MODEL=gemini-3-flash-preview
FALLBACK_MODEL=gemini-1.5-flash

# Provider API Keys (at least one required)

# Google AI Studio (gemini models)
GOOGLE_API_KEY=your-google-api-key

# OpenAI (gpt models) - optional
# OPENAI_API_KEY=your-openai-api-key

# Anthropic (claude models) - optional
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Supabase Integration (for user-authenticated tool operations)
# When Hermes is called via the Supabase Edge Function proxy,
# these credentials allow tools to make authenticated Supabase API calls
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# Service role key (optional, for admin operations bypassing RLS)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Enable Hermes Telemetry
# HERMES_TELEMETRY_ENABLED=true

# Optional: Custom skills directory
# HERMES_SKILLS_DIR=/root/.hermes/skills